<!DOCTYPE html>
<html>
<head>
	<link rel="stylesheet" href="styles">
	<link rel="preconnect" href="https://fonts.googleapis.com"> 
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin> 
	<link href="https://fonts.googleapis.com/css2?family=Source+Code+Pro:wght@400&display=swap" rel="stylesheet">
	<title>NB</title>
</head>
<body>
<main>
	<h1>{{strings.header}}</h1>
		<p class="intro">{{strings.intro}}</p>
		<p class="intro">{{strings.intro2}}</p>
	<h2>Projects</h2>
	<div class="project">
		<a href="{{strings.undebitLink}}"><img src="images/undebit.png" class="app-icon"></a>
		<div class="project-desc">
			<h3>Undebit</h3>
			<p>{{strings.undebitDesc}}</p>
			<p><a href="{{strings.undebitLink}}">View on the App Store</a></p>
		</div>
	</div>
	<h2>Skills</h2>
	<h3>Primary</h3>
		<p class="expl">Technologies I'm very profecient in:</p>
		<p>{{#each arrays.tech1}}<span class="capsule">{{this}}</span>{{/each}}</p>
	<h3>Secondary</h3>
	<p class="expl">Technologies I'm able to work with:</p>
		<p>{{#each arrays.tech2}}<span class="capsule">{{this}}</span>{{/each}}</p>
	<h3>Tools</h3>
		<p>{{#each arrays.tools}}<span class="capsule">{{this}}</span>{{/each}}</p>
</main>
</body>
</html>